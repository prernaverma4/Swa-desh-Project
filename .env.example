# =============================================================================
# ENVIRONMENT VARIABLES FOR DIGITAL CATALYST
# =============================================================================
# 
# This file shows all environment variables used by the application.
# Copy this to .env for local development (optional - app works without it)
# 
# FOR RENDER DEPLOYMENT:
# - Don't copy this file to Render
# - Set variables in Render Dashboard → Environment tab
# - Most variables are auto-set by render.yaml
# =============================================================================

# -----------------------------------------------------------------------------
# SECRET KEY (Required)
# -----------------------------------------------------------------------------
# Used for session encryption and security
# Local: Use any random string
# Render: Auto-generated by render.yaml (generateValue: true)
SECRET_KEY=your-secret-key-here-change-this-to-random-string

# -----------------------------------------------------------------------------
# DATABASE URL (Required)
# -----------------------------------------------------------------------------
# Local: SQLite file-based database (default)
# Render: PostgreSQL connection string (auto-set from database)
DATABASE_URL=sqlite:///instance/database.db

# -----------------------------------------------------------------------------
# FLASK ENVIRONMENT (Optional)
# -----------------------------------------------------------------------------
# development: Debug mode, auto-reload
# production: Optimized, no debug
FLASK_ENV=production

# -----------------------------------------------------------------------------
# PORT (Optional)
# -----------------------------------------------------------------------------
# Local: Port to run the app (default: 5002)
# Render: Auto-set by platform (usually 10000)
PORT=5002

# =============================================================================
# NOTES
# =============================================================================
# 
# 1. CHATBOT:
#    - No API keys needed!
#    - Rule-based chatbot (works offline)
#    - No OpenAI, no external APIs
# 
# 2. DATABASE:
#    - Local: SQLite (auto-created in instance/database.db)
#    - Render: PostgreSQL (created via render.yaml)
#    - Auto-switches based on DATABASE_URL
# 
# 3. EXTERNAL SERVICES:
#    - None required!
#    - App is completely self-contained
#    - No third-party API keys needed
# 
# 4. SECURITY:
#    - Never commit .env to git (already in .gitignore)
#    - Change SECRET_KEY in production
#    - Use strong random strings
# 
# 5. RENDER DEPLOYMENT:
#    - DATABASE_URL: Auto-set from PostgreSQL database
#    - SECRET_KEY: Auto-generated
#    - PORT: Auto-set by platform
#    - PYTHON_VERSION: Set in render.yaml (3.11.9)
# 
# =============================================================================
